{
  "name": "live-print-client",
  "version": "2026.03.14",
  "main": "electron/main.js",
  "type": "module",
  "author": "Dimitrios Chondrokoukis",
  "description": "This is the client app for the Live Print System",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "electron:serve": "concurrently \"ng serve\" \"wait-on http://localhost:4200 && electron .\"",
    "electron:build": "ng build --base-href ./ && electron-builder --config electron-builder.json"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.4",
    "@angular/cdk": "^21.2.2",
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/forms": "^21.2.4",
    "@angular/material": "^21.2.2",
    "@angular/platform-browser": "^21.2.4",
    "@angular/platform-browser-dynamic": "^21.2.4",
    "@angular/router": "^21.2.4",
    "@electron/remote": "^2.1.3",
    "@noble/ed25519": "^2.2.3",
    "@noble/hashes": "^1.8.0",
    "angularx-qrcode": "^21.0.5",
    "canvas": "^3.2.0",
    "concurrently": "^9.2.1",
    "electron-store": "^11.0.2",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "wait-on": "^9.0.4",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.4",
    "@types/jasmine": "~5.1.7",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "node-abi": "^4.27.0",
    "typescript": "~5.9.3"
  }
}
